# Parking Vision POC - Environment Configuration
# Copy this file to .env and update with your actual values

# ===========================================
# MQTT CONFIGURATION (ChirpStack LoRaWAN)
# ===========================================

# Enable or disable MQTT listener (default: 1 - enabled)
# Set to 0 to disable MQTT subscription
ENABLE_MQTT=1

# MQTT broker address
# Use "localhost" if ChirpStack is running on the same machine
MQTT_BROKER=localhost

# MQTT broker port (default: 1883)
MQTT_PORT=1883

# MQTT topic pattern for LoRaWAN uplink messages
# Default pattern subscribes to all devices across all applications
MQTT_TOPIC=application/+/device/+/event/up

# ===========================================
# CAMERA CONTROL CONFIGURATION
# ===========================================

# Enable or disable camera control (default: false)
# Set to "true", "1", or "yes" to enable camera movement and image capture
# When disabled, alerts will still work but without images
ENABLE_CAMERA_CONTROL=false

# Camera IP address
# Replace with your PTZ camera's IP address
CAMERA_IP=192.168.1.100

# Camera authentication credentials
# Update with your camera's username and password
CAMERA_USER=admin
CAMERA_PASS=admin

# RTSP stream URL (optional)
# If not set, will be auto-generated from CAMERA_IP, CAMERA_USER, and CAMERA_PASS
# Format: rtsp://username:password@ip:port/stream_path
# CAMERA_RTSP_URL=rtsp://admin:admin@192.168.1.100:554/stream1

# ===========================================
# EXAMPLE CONFIGURATIONS
# ===========================================

# --- Development/Testing (no camera) ---
# ENABLE_MQTT=1
# MQTT_BROKER=localhost
# ENABLE_CAMERA_CONTROL=false

# --- Production with camera ---
# ENABLE_MQTT=1
# MQTT_BROKER=192.168.1.50
# ENABLE_CAMERA_CONTROL=true
# CAMERA_IP=192.168.1.100
# CAMERA_USER=admin
# CAMERA_PASS=SecurePassword123
# CAMERA_RTSP_URL=rtsp://admin:SecurePassword123@192.168.1.100:554/stream1

# ===========================================
# CHIRPSTACK gRPC API CONFIGURATION
# ===========================================

# ChirpStack server host (default: localhost)
CHIRPSTACK_HOST=localhost

# ChirpStack gRPC port (default: 8080)
CHIRPSTACK_GRPC_PORT=8080

# API token from ChirpStack web UI
# Generate at: http://localhost:8080/#/api-keys
CHIRPSTACK_API_TOKEN=

# Application UUID from ChirpStack > Applications
CHIRPSTACK_APP_ID=
